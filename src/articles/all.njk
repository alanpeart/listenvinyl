---
layout: layouts/base.njk
title: "All Articles — Listen Vinyl"
description: "Every listening guide, gear review, and discovery feature from Listen Vinyl."
permalink: /articles/
---

<section class="section" style="padding-top:4rem">
  <div class="container">

    <div class="tech-rule" style="margin-bottom:2rem">
      <span class="tech-rule__line"></span>
      <span class="tech-rule__tick">ALL ARTICLES</span>
      <span class="tech-rule__line" style="max-width:80px"></span>
    </div>

    <p style="font-family:var(--font-mono);font-size:0.75rem;color:var(--text-muted);letter-spacing:0.08em;margin-bottom:3rem">
      {{ collections.posts | length }} TRANSMISSIONS ON FILE
    </p>

    <div class="cards-grid">
      {% for post in collections.posts %}
      <article class="card">
        <div class="card__body" style="padding-top:1.25rem">
          <div class="card__meta">
            <span class="tag tag--{{ post.data.tag_class | replace('tag--','') }}">{{ post.data.category }}</span>
            <span style="font-family:var(--font-mono);font-size:0.6rem;color:var(--text-muted);letter-spacing:0.08em;margin-left:auto">{{ post.data.ref }}</span>
          </div>
          <h2 class="card__title" style="margin-top:0.75rem">
            <a href="{{ post.url }}" style="color:inherit;text-decoration:none">{{ post.data.title }}</a>
          </h2>
          <p class="card__excerpt">{{ post.data.description }}</p>
          <div class="card__footer">
            <span>{{ post.data.read_time }}</span>
            <a href="{{ post.url }}" class="card__read-more">Read</a>
          </div>
        </div>
      </article>
      {% endfor %}
    </div>

  </div>
</section>
